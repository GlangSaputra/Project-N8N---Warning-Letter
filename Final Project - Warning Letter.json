    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ===============================\n// GET DATA DARI FORM\n// ===============================\nconst formData = $('On form submission1').first().json;\n\n// ===============================\n// GET HISTORY DARI NOTION\n// ===============================\nconst historyItems = $('SP History').all();\n\n// Filter item valid\nconst validHistory = historyItems.filter(\n  item => Object.keys(item.json).length > 0\n);\n\n// ===============================\n// AMBIL NAMA KARYAWAN\n// ===============================\nconst namaKaryawan = formData[\"Nama Karyawan\"] || \"Unknown\";\n\n// Bersihkan nama untuk nomor SP\nconst cleanName = namaKaryawan.replace(/\\s+/g, '');\n\n// ===============================\n// AMBIL SP TERAKHIR\n// ===============================\nlet lastSP = null;\n\nif (validHistory.length > 0) {\n\n  // Ambil record terbaru\n  const latestRecord = validHistory[0].json;\n\n  // Ambil level SP dari Notion\n  lastSP =\n    latestRecord.property_level_sp ||\n    latestRecord.sp_level ||\n    latestRecord.LevelSP ||\n    latestRecord[\"Level SP\"] ||\n    null;\n}\n\n// ===============================\n// TENTUKAN LEVEL SP BERIKUTNYA\n// ===============================\nlet spLevel = '';\nlet spNumber = '';\nlet nextAction = '';\n\nconst timestamp = new Date().getTime();\n\n// Belum pernah kena SP\nif (!lastSP) {\n\n  spLevel = 'SP1';\n  spNumber = `SP1-${cleanName}-${timestamp}`;\n  nextAction = 'create_letter';\n\n// Sudah pernah kena SP1\n} else if (lastSP === 'SP1') {\n\n  spLevel = 'SP2';\n  spNumber = `SP2-${cleanName}-${timestamp}`;\n  nextAction = 'create_letter';\n\n// Sudah pernah kena SP2\n} else if (lastSP === 'SP2') {\n\n  spLevel = 'SP3';\n  spNumber = `SP3-${cleanName}-${timestamp}`;\n  nextAction = 'create_letter';\n\n// Sudah pernah kena SP3\n} else {\n\n  spLevel = 'ESCALATE';\n  spNumber = `ESC-${cleanName}-${timestamp}`;\n  nextAction = 'escalate_to_hr';\n}\n\n// ===============================\n// RETURN DATA\n// ===============================\nreturn {\n  json: {\n\n    // Data form asli\n    ...formData,\n\n    // SP sebelumnya\n    previous_sp: lastSP,\n\n    // SP baru\n    sp_level: spLevel,\n    sp_number: spNumber,\n\n    // Jumlah histori\n    sp_count: validHistory.length,\n\n    // Action berikutnya\n    next_action: nextAction,\n\n    // Tanggal SP\n    tanggal_sp: new Date().toISOString().split('T')[0]\n  }\n};"
      },
      "id": "62cb93d9-7c6b-4503-8991-86cb60e78661",
      "name": "Determine SP Level",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        880
      ]
    },
